<%- include('../partials/header') %>

<div class="card">
  <h1>Forgot Password</h1>
  <p>Enter your university email and we'll send you a reset link (valid for 1 hour).</p>

  <form action="/auth/forgot-password" method="POST" class="form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-group">
      <label for="email">University Email</label>
      <input type="email" id="email" name="email" required placeholder="you@westminster.ac.uk" />
    </div>
    <button type="submit" class="btn btn-primary btn-full">Send Reset Link</button>
  </form>

  <p class="text-center"><a href="/auth/login">Back to Login</a></p>
</div>

<%- include('../partials/footer') %>
