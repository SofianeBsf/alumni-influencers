<%- include('../partials/header') %>

<div class="card">
  <h1>My Bid History</h1>
  <% if (bids.length === 0) { %>
    <p class="text-muted">No bids placed yet.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr><th>Date</th><th>Amount</th><th>Status</th><th>Updates</th></tr>
      </thead>
      <tbody>
        <% bids.forEach(b => { %>
          <tr>
            <td><%= new Date(b.bidDay).toLocaleDateString('en-GB') %></td>
            <td>£<%= b.amount.toFixed(2) %></td>
            <td>
              <% if (b.status === 'won') { %><span class="badge badge-success">Won 🏆</span>
              <% } else if (b.status === 'lost') { %><span class="badge badge-error">Lost</span>
              <% } else { %><span class="badge badge-warning">Active</span><% } %>
            </td>
            <td><%= b.updateHistory ? b.updateHistory.length : 0 %> update(s)</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
  <a href="/bidding" class="btn btn-secondary">Back to Bidding</a>
</div>

<%- include('../partials/footer') %>
