<%- include('../partials/header') %>

<div class="admin-page">
  <h1>Usage Statistics</h1>

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-value"><%= totalRequests %></div>
      <div class="stat-label">Total Requests</div>
    </div>
    <div class="stat-card">
      <div class="stat-value"><%= failedAuth %></div>
      <div class="stat-label">Failed Auth Attempts</div>
    </div>
  </div>

  <div class="card">
    <h2>Activity (Last 7 Days)</h2>
    <table class="table">
      <thead><tr><th>Date</th><th>Requests</th></tr></thead>
      <tbody>
        <% dailyActivity.forEach(d => { %>
          <tr><td><%= d._id %></td><td><%= d.count %></td></tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% clientStats.forEach(cs => { %>
    <div class="card">
      <h2><%= cs.client.name %> <span class="badge <%= cs.client.isActive ? 'badge-success' : 'badge-error' %>"><%= cs.client.isActive ? 'Active' : 'Revoked' %></span></h2>
      <p>Token: <code><%= cs.client.tokenPrefix %>...</code> | Scope: <strong><%= cs.client.scope %></strong></p>
      <div class="stats-row">
        <div class="stat-card"><div class="stat-value"><%= cs.totalRequests %></div><div class="stat-label">Total Requests</div></div>
        <div class="stat-card"><div class="stat-value"><%= cs.successfulRequests %></div><div class="stat-label">Successful</div></div>
        <div class="stat-card"><div class="stat-value"><%= cs.lastRequest ? new Date(cs.lastRequest).toLocaleString('en-GB') : 'Never' %></div><div class="stat-label">Last Request</div></div>
      </div>
      <h4>Endpoint Breakdown</h4>
      <table class="table">
        <thead><tr><th>Endpoint</th><th>Count</th></tr></thead>
        <tbody>
          <% Object.entries(cs.endpointBreakdown).forEach(([ep, count]) => { %>
            <tr><td><%= ep %></td><td><%= count %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% }) %>
</div>

<%- include('../partials/footer') %>
