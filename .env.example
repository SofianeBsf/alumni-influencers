# =============================================
# ALUMNI INFLUENCERS - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control

# --- Server ---
PORT=3000
NODE_ENV=development

# --- MongoDB ---
# Local:  mongodb://localhost:27017/alumni_influencers
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/alumni_influencers
MONGODB_URI=mongodb://localhost:27017/alumni_influencers

# --- Session Secret (generate a long random string) ---
SESSION_SECRET=your_very_long_random_session_secret_here_change_this

# --- Email (Gmail) ---
# Use a Gmail account with an App Password (not your real password)
# Enable 2FA on your Google account, then go to:
# Google Account > Security > App Passwords > generate one
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password_16_chars
EMAIL_FROM=Alumni Influencers <your_gmail_address@gmail.com>

# --- University Email Domain ---
# Only emails from this domain can register (e.g. westminster.ac.uk)
UNIVERSITY_DOMAIN=westminster.ac.uk

# --- App URL (used in email links) ---
APP_URL=http://localhost:3000

# --- Admin API Key (for admin dashboard access) ---
# Generate a strong random string for your admin API key
ADMIN_API_KEY=your_admin_api_key_here_change_this

# --- JWT / Token Settings ---
# Used for email verification and password reset tokens (in hours)
VERIFICATION_TOKEN_EXPIRY_HOURS=24
RESET_TOKEN_EXPIRY_HOURS=1
