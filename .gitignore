# =============================================
# Alumni Influencers - .gitignore
# =============================================

# --- Environment Variables ---
.env
.env.local
.env.production

# --- Node Modules ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Uploaded Files (user profile images) ---
public/uploads/*
!public/uploads/.gitkeep

# --- Logs ---
logs/
*.log

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo

# --- Build / Cache ---
.npm/
.cache/

# --- Session Store (if using file-based sessions) ---
sessions/
